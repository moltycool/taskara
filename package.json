{
  "name": "taskara",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "plugins/*"
  ],
  "scripts": {
    "dev": "bun run --filter @taskara/api dev & bun run --filter @taskara/web dev & bun run dev:menubar",
    "dev:api": "bun run --filter @taskara/api dev",
    "dev:web": "bun run --filter @taskara/web dev",
    "dev:menubar": "bun run --filter @taskara/menubar dev",
    "build:menubar": "bun run --filter @taskara/menubar build",
    "release:menubar": "bun run --filter @taskara/menubar release",
    "dev:mattermost": "bun run --filter @taskara/mattermost-bot dev",
    "db:generate": "PRISMA_GENERATE_SKIP_AUTOINSTALL=1 bun prisma generate --schema packages/db/prisma/schema.prisma",
    "db:migrate": "bun prisma migrate dev --schema packages/db/prisma/schema.prisma",
    "db:push": "bun prisma db push --schema packages/db/prisma/schema.prisma",
    "db:studio": "bun prisma studio --schema packages/db/prisma/schema.prisma",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "bun run --filter '*' lint"
  },
  "devDependencies": {
    "@prisma/client": "6.19.3",
    "@types/bun": "latest",
    "prisma": "^6.6.0",
    "typescript": "^5.8.3"
  }
}
